# FastAPI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# LLM APIs
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# Embedding APIs
EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENROUTER_EMBEDDING_MODEL=text-embedding-3-large

# External travel APIs
OPENTRIPMAP_API_KEY=
GOOGLE_MAPS_API_KEY=
SKYSCANNER_API_KEY=

# Cloud vector store (Chroma over HTTP, not local)
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_API_KEY=
CHROMA_HOST=
CHROMA_PORT=443
CHROMA_SSL=true
CHROMA_COLLECTION=travel_itinerary_docs
